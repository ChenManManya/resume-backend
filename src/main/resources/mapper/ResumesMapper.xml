<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.chenmanman.resume.mapper.ResumesMapper">

    <resultMap id="BaseResultMap" type="cn.chenmanman.resume.domain.entity.resume.ResumesEntity">
            <id property="id" column="id" />
            <result property="userId" column="user_id" />
            <result property="title" column="title" />
            <result property="templateId" column="template_id" />
            <result property="status" column="status" />
            <result property="contentJson" column="content_json" />
            <result property="layoutJson" column="layout_json" />
            <result property="createBy" column="create_by" />
            <result property="updateBy" column="update_by" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
            <result property="isDeleted" column="is_deleted" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,title,template_id,status,content_json,layout_json,
        create_by,update_by,create_time,update_time,is_deleted
    </sql>

    <select id="getResumeMeList" resultType="cn.chenmanman.resume.domain.vo.resume.MyResumesVO">
        SELECT
            r.id AS id,
            r.title AS title,
            r.update_time AS updateTime,
            r.template_id AS templateId,
            t.preview_image_url AS previewImageUrl
        FROM resumes r
                 INNER JOIN templates t ON r.template_id = t.id
        WHERE r.user_id = #{userId}
        ORDER BY r.update_time DESC
    </select>
</mapper>
